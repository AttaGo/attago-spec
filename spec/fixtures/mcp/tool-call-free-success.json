{
  "description": "MCP tools/call — free tool (list_assets) returns without payment",
  "request": {
    "method": "POST",
    "path": "/v1/mcp",
    "headers": { "Content-Type": "application/json" },
    "body": {
      "jsonrpc": "2.0",
      "id": 3,
      "method": "tools/call",
      "params": {
        "name": "list_assets",
        "arguments": {}
      }
    }
  },
  "response": {
    "status": 200,
    "schema": "mcp-tool-result",
    "body": {
      "jsonrpc": "2.0",
      "id": 3,
      "result": {
        "content": [
          {
            "type": "text",
            "text": "{\"assets\":[{\"symbol\":\"BTC\",\"score\":72,\"confidence\":0.85,\"signal\":\"go\"}],\"count\":1}"
          }
        ],
        "isError": false
      }
    }
  }
}
